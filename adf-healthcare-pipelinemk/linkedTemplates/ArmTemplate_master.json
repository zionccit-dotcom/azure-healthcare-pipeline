{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-healthcare-pipelinemk"
		},
		"LS_ADLS_DataLake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://healthcaredatalakemk.dfs.core.windows.net/"
		},
		"LS_AzureSQL_Gold_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-healthcare-mk2.database.windows.net"
		},
		"LS_AzureSQL_Gold_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db-healthcare-gold"
		},
		"LS_AzureSQL_Gold_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"LS_REST_DiseaseSH_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://disease.sh/v3/covid-19/"
		},
		"LS_KeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-healthcare-mk.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-healthcare-pipelinemk_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_REST_DiseaseSH_properties_typeProperties_url": {
						"value": "[parameters('LS_REST_DiseaseSH_properties_typeProperties_url')]"
					},
					"LS_KeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_properties_typeProperties_baseUrl')]"
					},
					"LS_ADLS_DataLake_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_DataLake_properties_typeProperties_url')]"
					},
					"LS_AzureSQL_Gold_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_Gold_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_Gold_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_Gold_properties_typeProperties_database')]"
					},
					"LS_AzureSQL_Gold_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSQL_Gold_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}